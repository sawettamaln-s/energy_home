rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ข้อมูลผู้ใช้แต่ละคน + subcollection ทั้งหมด (bills, appliances,
    // electricity_logs, water_logs, fixed_costs, start_meter_history)
    // เจ้าของบัญชี (login แล้ว + uid ตรงกับ document) เท่านั้นที่อ่าน/เขียนได้
    // คนอื่นที่ login มาแล้วก็ยังห้ามแตะข้อมูลของคนอื่นอยู่ดี
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // อัตราค่าไฟ/น้ำกลาง (Ft rate, VAT) — ทุกคนที่ login แล้วอ่านได้
    // แต่ห้ามเขียนจากฝั่ง client เด็ดขาด (แก้ผ่าน Firebase Console เท่านั้น)
    match /app_config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // อะไรที่ไม่ตรงกับด้านบน ปฏิเสธหมดโดยปริยาย (ไม่ต้องเขียน deny เอง)
  }
}